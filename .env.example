# Database — Neon (https://neon.tech)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth
NEXTAUTH_SECRET=          # openssl rand -base64 32
ADMIN_EMAIL=you@example.com
ADMIN_PASSWORD_HASH=      # npx tsx scripts/hash-password.ts yourpassword
                          # IMPORTANT: escape every $ in the hash as \$
                          # e.g. ADMIN_PASSWORD_HASH=\$2b\$10\$abc...

# AI — OpenRouter (https://openrouter.ai)
DEEPSEEK_API_KEY=sk-or-v1-...
DEEPSEEK_BASE_URL=https://openrouter.ai/api/v1

# Storage — Vercel Blob (https://vercel.com/docs/storage/vercel-blob)
# Optional — only needed for image uploads
BLOB_READ_WRITE_TOKEN=

# App
NEXT_PUBLIC_BASE_URL=http://localhost:3000
